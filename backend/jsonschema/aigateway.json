      "items": {
        "type": [
          "string",
          "null"
        ]
      },
      "title": "deployments",
      "type": "array"
    },
    "description": {
      "$friendlyName": "Description",
      "description": "The description of the AI Gateway.",
      "title": "description",
      "type": [
        "string",
        "null"
      ]
    },
    "importHash": {
      "$creationOnly": true,
