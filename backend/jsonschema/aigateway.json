        "type": [
          "string",
          "null"
        ]
      },
      "title": "aigatewayconnectors",
      "type": "array"
    },
    "createTime": {
      "$friendlyName": "CreateTime",
      "$readOnly": true,
      "description": "Creation date of the object.",
      "title": "createTime",
      "type": [
        "string",
        "null"
      ]
    },
    "deployments": {
      "$friendlyName": "Deployments",
