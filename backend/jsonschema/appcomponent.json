{
  "$extends": [],
  "$friendlyName": "App Component",
  "$friendlyNamePlural": "App Components",
  "$modelName": "AppComponent",
  "$modelPackage": "lain",
  "$modelResourceName": "appcomponents",
  "$modelRestName": "appcomponent",
  "additionalProperties": false,
  "description": "Represents a particular component of the application.",
  "properties": {
    "description": {
      "$friendlyName": "Description",
      "description": "The description of the component.",
      "title": "description",
      "type": [
        "string",
        "null"
      ]
    },
    "egress": {
      "$friendlyName": "Egress",
      "$ref": "appcomponentegress.json",
      "description": "The egress configuration of the component.",
      "title": "egress"
    },
    "ingress": {
      "$friendlyName": "Ingress",
      "$ref": "appcomponentingress.json",
      "description": "The ingress configuration of the component.",
      "title": "ingress"
    },
    "kind": {
      "$defaultValue": "Other",
      "$friendlyName": "Kind",
      "description": "The kind of component.",
      "enum": [
        "Agent",
        "Tool",
        "Model",
        "VectorDB",
        "Other"
      ],
      "title": "kind"
    },
    "name": {
      "$friendlyName": "Name",
      "$required": true,
      "description": "The component name.",
      "pattern": "^[a-zA-Z0-9-_]+$",
      "title": "name",
      "type": "string"
    },
    "selector": {
      "$friendlyName": "Selector",
      "$ref": "appcomponentselector.json",
      "$required": true,
      "description": "The selector configuration that identifies workload groups as this app component.",
      "title": "selector"
    },
    "token": {
      "$friendlyName": "Token",
      "$readOnly": true,
      "description": "The token for the current component. Only populated by the backend when the caller's claim match the parents app.subject.",
      "title": "token",
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "name",
    "selector"
  ],
  "title": "AppComponent",
  "type": "object"
}