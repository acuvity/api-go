{
  "components": {
    "schemas": {
      "accesspolicy": {
        "description": "Access Policies define rules governing how users can interact with a provider.\nThey control whether access is permitted or denied and can enforce additional\nbehaviors, such as redacting sensitive data, issuing warnings for problematic\nqueries, and other security or compliance measures by applying Content Policies.",
        "properties": {
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "accessDeniedMessage": {
            "description": "The message that is sent if the access is denied.",
            "example": "You must use the company workspace",
            "type": "string"
          },
          "action": {
            "default": "Allow",
            "description": "Define if the provider is allowed or denied for the match expression.",
            "enum": [
              "Allow",
              "Deny",
              "Redirect"
            ]
          },
          "alertDefinition": {
            "description": "The definition to use for alerting when action is deny.",
            "type": "string"
          },
          "contentPolicies": {
            "description": "The list of content policies to apply when the user has access to the provider.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "createTime": {
            "description": "Creation date of the object.",
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          },
          "description": {
            "description": "Description of the access policy.",
            "type": "string"
          },
          "disabled": {
            "description": "If true, the policy is disabled.",
            "type": "boolean"
          },
          "importHash": {
            "description": "The hash of the structure used to compare with new import version.",
            "type": "string"
          },
          "importLabel": {
            "description": "The user-defined import label that allows the system to group resources from the\nsame import operation.",
            "type": "string"
          },
          "match": {
            "description": "The match criteria used to take a decision on the access.",
            "example": "[\n  {\n    \"key\": \"Team\"\n    \"operator\": \"Any\"\n    \"values\": [\"engineers\"]\n  }\n]",
            "items": {
              "$ref": "#/components/schemas/predicate"
            },
            "type": "array"
          },
          "minimalLogging": {
            "description": "If true, the system will not log the messages that are not considered as\nviolations.",
            "type": "boolean"
          },
          "name": {
            "description": "The name of the access policy.",
            "example": "my access policy",
            "type": "string"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "offbandAnalysis": {
            "description": "If true, the system will run analysis in parallel of the user request. When this\nis active, no further policing will be done, and no content policy will run.\nThis can be used to observe the transmitted data and have analysis report,\nwithout adding latency to the end user request, at the price of not being able\nto do any form of content moderation.",
            "type": "boolean"
          },
          "permissive": {
            "description": "If set, just log the decision, but don't enforce it.",
            "type": "boolean"
          },
          "redirectMessage": {
            "description": "If set, show this message to user before the redirection.",
            "type": "string"
          },
          "redirectURL": {
            "description": "If set, redirect the user to that URL.",
            "type": "string"
          },
          "updateTime": {
            "description": "Last update date of the object.",
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "admindomainanalysis": {
        "description": "Administrative API to send a request to analyze a domain.",
        "properties": {
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "domain": {
            "description": "Domain to analyze. The analysis will be sent to refractai.",
            "example": "chatgpt.com",
            "type": "string"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "processing": {
            "default": "Queue",
            "description": "Type of processing for refractai. Queue means the the processing will be batched\nand will be done later on. Immediate skips the queue and is done as soon as\npossible. Finally RequireValidation will put it a queue and will require manual\nintervention.",
            "enum": [
              "Queue",
              "Immediate",
              "RequireValidation"
            ]
          },
          "provider": {
            "description": "Provider name to related to the domain.",
            "example": "chatgpt",
            "type": "string"
          }
        },
        "required": [
          "domain"
        ],
        "type": "object"
      },
      "adminmagiclink": {
        "description": "Administrative API to create magic links.",
        "properties": {
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "passcode": {
            "$ref": "#/components/schemas/passcode"
          }
        },
        "type": "object"
      },
      "adminorg": {
        "description": "Administrative API to create new organizations.",
        "properties": {
          "CTSID": {
            "description": "External customer/tenant identifier for DSG customer mapping.",
            "type": "string"
          },
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "forceReimportTemplate": {
            "description": "This property if true will force reimport the template data. Setting it false is\na noop.",
            "type": "boolean"
          },
          "githubSigninEnabled": {
            "description": "Enables the global Sign In With Github for the organization.",
            "type": "boolean"
          },
          "gitlabSigninEnabled": {
            "description": "Enables the global Sign In With Gitlab for the organization.",
            "type": "boolean"
          },
          "googleSigninEnabled": {
            "description": "Enables the global Sign In With Google for the organization.",
            "type": "boolean"
          },
          "huggingfaceSigninEnabled": {
            "description": "Enables the global Sign In With Huggingface for the organization.",
            "type": "boolean"
          },
          "mode": {
            "default": "Normal",
            "description": "The mode of the organization.",
            "enum": [
              "Trial",
              "TrialEmployees",
              "TrialApps",
              "Pilot",
              "Normal",
              "NormalEmployees",
              "NormalApps",
              "Blocked",
              "Dead"
            ]
          },
          "name": {
            "description": "The name of the organization.",
            "example": "acme.com",
            "type": "string"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "reimportTemplate": {
            "description": "This is an internal property used to decide if the org template needs to be\nreimported.",
            "readOnly": true,
            "type": "boolean"
          },
          "subject": {
            "description": "A tag expression that identifies the authorized user(s). If set it will\nconfigure the complete subject of the admin api authorization, ignoring anything\npassed in claims.",
            "items": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": "array"
          },
          "type": {
            "default": "Full",
            "description": "The type of organization. Either Full or Single. Full represents an organization\nthat will need to onboard additional users, while Single represents a single\nuser account.",
            "enum": [
              "Full",
              "Single"
            ]
          }
        },
        "required": [
          "name"
        ],
        "type": "object"
      },
      "agent": {
        "description": "Displays the status of Acushield agents deployed on users’ machines, providing\ninsights into their operational state and activity.",
        "properties": {
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "agentConfig": {
            "$ref": "#/components/schemas/agentconfig"
          },
          "currentVersion": {
            "description": "The current version of the agent.",
            "example": "0.1.0",
            "type": "string"
          },
          "hostname": {
            "description": "The name of the host where the agent is running.",
            "example": "this-hostname",
            "type": "string"
          },
          "importHash": {
            "description": "The hash of the structure used to compare with new import version.",
            "type": "string"
          },
          "importLabel": {
            "description": "The user-defined import label that allows the system to group resources from the\nsame import operation.",
            "type": "string"
          },
          "isAPEXReachable": {
            "description": "True if the apex is reachable.",
            "type": "boolean"
          },
          "isAPEXTrusted": {
            "description": "True if the apex is trusted.",
            "type": "boolean"
          },
          "managedCAState": {
            "description": "The state of the managed CA.",
            "type": "boolean"
          },
          "managedInterfaces": {
            "description": "The list of managed interfaces.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "ping": {
            "description": "The last ping recorded for the agent.",
            "example": "2024-06-21T00:36:15.021Z",
            "format": "date-time",
            "type": "string"
          },
          "principal": {
            "$ref": "#/components/schemas/principal"
          },
          "start": {
            "description": "The start time for the agent.",
            "example": "2024-06-21T00:36:15.021Z",
            "format": "date-time",
            "type": "string"
          },
          "status": {
            "description": "The status of the agent.",
            "enum": [
              "Alive",
              "Paused",
              "Stopped"
            ],
            "example": "Alive"
          },
          "systemProxyManagementState": {
            "description": "The state of the system proxy management.",
            "type": "boolean"
          }
        },
        "required": [
          "currentVersion",
          "hostname",
          "ping",
          "principal",
          "start",
          "status"
        ],
        "type": "object"
      },
      "agentconfig": {
        "description": "Stores the configuration information for the acushield agent.",
        "properties": {
          "DNSMonitorDisabled": {
            "description": "If disabled, the agent will not monitor DNS traffic.",
            "type": "boolean"
          },
          "DNSMonitorPolicy": {
            "default": "Warn",
            "description": "What action to take if the DNS monitor cannot start when enabled. Enforce will\nstop the agent with an error, while Warn will post a log and continue on.",
            "enum": [
              "Warn",
              "Enforce"
            ]
          },
          "ID": {
            "description": "ID is the identifier of the object.",
            "readOnly": true,
            "type": "string"
          },
          "attendedUpgrades": {
            "description": "If true, upgrades will only take place with user confirmation.",
            "type": "boolean"
          },
          "configRefreshInterval": {
            "default": "1h",
            "description": "Defines the refresh interval for the configuration of the deployed agents (i.e:\n30m, 6h).",
            "example": "30m",
            "type": "string"
          },
          "createTime": {
            "description": "Creation date of the object.",
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          },
          "description": {
            "description": "Description of the agent configuration.",
            "type": "string"
          },
          "domainDiscoveryDisabled": {
            "description": "If disabled, the agent will stop reporting the discovered domains.",
            "type": "boolean"
          },
          "domainReportInterval": {
            "default": "10m",
            "description": "The interval in which domains (visited URLs or DNS) are reported.",
            "example": "30m",
            "type": "string"
          },
          "emergencyPauseEnabled": {
            "description": "Use this option in emergencies if your users are being blocked.\nWhen enabled, it will force all agents to pause at the next refresh of their\nconfiguration or when the user clicks “Reload” on their laptop.\nWhen paused, agents are not enforcing security rules.",
            "type": "boolean"
          },
          "importHash": {
            "description": "The hash of the structure used to compare with new import version.",
            "type": "string"
          },
          "importLabel": {
            "description": "The user-defined import label that allows the system to group resources from the\nsame import operation.",
            "type": "string"
          },
          "listeningPort": {
            "default": "8081",
            "description": "The port used by the agent to proxy the traffic.",
            "type": "string"
          },
          "managedCADisabled": {
            "description": "If disabled, the agent will rely on the CA already installed and trusted on the\nsystem.",
            "type": "boolean"
          },
          "metricsEnabled": {
            "description": "If enabled, the agent will start reporting various metrics in logs.",
            "type": "boolean"
          },
          "name": {
            "description": "The name of the agent configuration.",
            "example": "default",
            "type": "string"
          },
          "namespace": {
            "description": "The namespace of the object.",
            "readOnly": true,
            "type": "string"
          },
          "pacName": {
            "description": "The name of the PAC configuration to use.",
            "example": "default",
            "type": "string"
          },
          "pauseEnabled": {
            "description": "If enabled, the agent will have the ability to pause enforcement.",
            "type": "boolean"
          },
          "pingInterval": {
            "default": "6h",
            "description": "The ping interval at which acushield should check in with the backend.",
            "example": "6h",
            "type": "string"
          },
          "releaseTrain": {
            "default": "Stable",
            "description": "The release train to follow when updating. Manual means it will not auto-update,\nessentially pinning to a version.",
            "enum": [
              "Manual",
              "Unstable",
              "Stable"
            ]
          },
          "scanDisabled": {
            "description": "If disabled, the agent will not scan for genAI applications and plugins.",
            "type": "boolean"
          },
          "scanInstalledApps": {
            "description": "The list of installed applications the scanner will look for.",
            "items": {
              "$ref": "#/components/schemas/agentdiscoveredapp"
            },
            "type": "array"
          },
          "scanInterval": {
            "default": "5m",
            "description": "The interval in which scans take place by the agent.",
            "example": "10m",
            "type": "string"
          },
          "scanReportInterval": {
            "default": "12h",
            "description": "The interval in which scan reports are sent to the backend.",
            "example": "1h",
            "type": "string"
          },
          "scanRunningProcesses": {
            "description": "The list of running processes the scanner will look for.",
            "items": {
              "type": "string"
            },
            "readOnly": true,
            "type": "array"
          },
          "subject": {
            "description": "A tag expression that identifies the user(s) tied to this config.",
            "example": [
              [
                "@scope=employees",
                "@org=acuvity.ai"
              ]
            ],
            "items": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "type": "array"
          },
          "systemProxyManagementDisabled": {
            "description": "If disabled, the system proxy needs to be configured manually.",
            "type": "boolean"
          },
          "tunnelEnabled": {
            "description": "If enabled, the agent will use a tunnel to connect to the Acuvity apex, and the\napex will make its requests to the destination back through the agent over the\nsame tunnel.",
            "type": "boolean"
          },
          "tunnelProxyAuth": {
            "$ref": "#/components/schemas/tunnelproxyauth"
          },
          "tunnelProxyHeaders": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "If you are using a proxy server for the tunnel connection, you can specify\nadditional headers to be sent with the requests to the proxy.",
            "type": "object"
          },
          "tunnelProxyURL": {
            "description": "If tunnels are enabled, and the system requires the use of an HTTP proxy server,\nthen this is the URL of the proxy server to use.\nIt must be a full URL including the scheme (http or https) and optionally a\nport. The proxy will be used not only for the tunnel connection, but also for\nall requests to the final destination.",
            "example": "http://proxy.example.com:8080",
            "type": "string"
          },
          "updateTime": {
            "description": "Last update date of the object.",
            "format": "date-time",
            "readOnly": true,
            "type": "string"
          },
          "useDynamicPort": {
            "description": "If system proxy management is enabled and this flag is enabled, the system\ncan take another port, different than the listeningPort.",
            "type": "boolean"
          }
        },
        "required": [
          "listeningPort",
          "name",
          "subject"
        ],
        "type": "object"
      },
