          "defaultPolicyAccessDeniedMessage": {
            "description": "The message that is sent if the access is denied by the default policy deny\naction.",
            "example": "Access Denied",
            "type": "string"
          },
          "defaultPolicyAction": {
            "default": "Allow",
            "description": "The default action to take for connections ingressing to the proxy of this\nworkload that do not match any of the policies.",
            "enum": [
              "Allow",
              "Deny"
            ]
          },
          "dialTLS": {
            "default": "Preserve",
            "description": "This option controls the dialing behaviour of the apex to the origin server.\nShould be explicitly set to enabled if the origin expects TLS connections. And\nvice versa it should be set to disabled if the origin expects connections in\nplaintext. By default this setting is set to preserve which means that the apex\nis going to dial using whatever mode it terminated its own connection with: if\nthe apex received a TLS connection, it will dial TLS, if it received a plaintext\nconnection, then it will dial plaintext. The apex receiving behaviour can be\ncontrolled with the listenTLS option. As a last resort this setting can be set\nto auto detect which means that the apex is going to probe the origin server to\ndetermine if it needs to dial using TLS or not. Note that this is potentially\nsending a TLS Client Hello to a plaintext HTTP server which is not expecting\nthat. Therefore, this option is not recommended if it can be avoided.",
            "enum": [
              "Preserve",
              "AutoDetect",
              "Enabled",
              "Disabled"
            ]
          },
          "listenTLS": {
            "default": "AutoDetect",
            "description": "This option controls the receiving behaviour of connection to the apex before\nthey are going to be proxied to the origin server. To control the dialing\nbehaviour of the apex towards the origin server use the dialTLS option. Should\nbe explicitly set to enabled if the listener expects TLS connections. And vice\nversa it should be set to disabled if the listener expects connections in\nplaintext. By default this setting is set to auto detect which means that the\nlistener will automatically determine if incoming connections are TLS or not:\nTLS connections will be accepted, as well as  plain TCP connections will be\naccepted, both on the configured listenPort.",
            "enum": [
              "AutoDetect",
              "Enabled",
              "Disabled"
            ]
          },
          "policies": {
            "description": "The defined policies for this ingress listener.",
            "items": {
              "$ref": "#/components/schemas/ingresspolicy"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
